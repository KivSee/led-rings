{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "UI: Launch Chrome against Vite",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/ui",
      "sourceMaps": true,
      "preLaunchTask": "ui: dev"
    },
    {
      "name": "Backend: control-server",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "yarn",
      "runtimeArgs": ["control-server"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
