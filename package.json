{
  "name": "led-rings",
  "version": "0.0.1",
  "main": "index.js",
  "repository": "git@github.com:KivSee/led-rings.git",
  "scripts": {
    "test": "ts-node-dev --respawn src/test.ts",
    "sync-segments": "ts-node src/ring-segments/index.ts",
    "lilum-segments": "ts-node src/lilum/segments.ts",
    "lilum": "ts-node src/lilum/lilum.ts",
    "start": "ts-node-dev --respawn src/index.ts",
    "playground": "ts-node-dev --respawn src/playground.ts",
    "idle": "ts-node-dev --respawn src/idle.ts",
    "stop": "ts-node-dev --respawn src/stop.ts",
    "clock": "ts-node src/clock.ts",
    "random": "ts-node-dev --respawn src/random.ts",
    "index-trigger": "ts-node-dev --respawn src/index-trigger.ts",
    "preset": "ts-node src/preset-runner.ts",
    "play": "ts-node src/play-preset.ts",
    "loop": "ts-node src/songs/loop.ts",
    "buttons": "ts-node-dev --respawn src/songs/buttons.ts",
    "agent": "ts-node-dev --respawn src/songs/agent.ts",
    "control-server": "ts-node-dev --respawn src/control-server.ts",
    "ui": "yarn --cwd ui dev",
    "dev": "concurrently -n server,ui -c blue,magenta \"yarn control-server\" \"yarn ui\"",
    "export-song": "ts-node src/export-song.ts",
    "gen-ui-song": "ts-node src/generate-category-ui-song.ts"
  },
  "dependencies": {
    "@types/node": "^22.10.10",
    "axios": "^1.13.6",
    "dotenv": "^16.4.7",
    "env-var": "^7.5.0",
    "mqtt": "^5.15.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3"
  },
  "resolutions": {
    "minimatch": ">=3.1.4",
    "brace-expansion": ">=1.1.12",
    "diff": ">=4.0.4"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
